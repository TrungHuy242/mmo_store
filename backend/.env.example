# ===== Server =====
NODE_ENV=development
PORT=5000
# URL cong khai cua backend (dung cho Telegram webhook), vd: https://api.yourdomain.com
PUBLIC_BASE_URL=http://localhost:5000
# URL frontend (dung cho affiliate link, CORS)
FRONTEND_URL=http://localhost:5173

# ===== Database =====
MONGO_URI=mongodb://mongo:27017/mmostore

# ===== Auth / Security =====
JWT_SECRET=thay_bang_chuoi_ngau_nhien_that_dai
JWT_EXPIRES_IN=7d
# Khoa AES 32 ky tu (256-bit) de ma hoa du lieu giao hang nhay cam
ENCRYPTION_KEY=thay_bang_32_ky_tu_ngau_nhien_abcdef

# ===== Telegram Bot =====
TELEGRAM_BOT_TOKEN=
# Chat ID cua admin de nhan canh bao ton kho / bao cao
TELEGRAM_ADMIN_CHAT_ID=
# Bat webhook (true) hay polling (false). Production dung true.
TELEGRAM_USE_WEBHOOK=false
# Secret token bao ve endpoint webhook telegram
TELEGRAM_WEBHOOK_SECRET=thay_bang_chuoi_ngau_nhien

# ===== Payment: USDT TRC20 =====
TRONGRID_API_KEY=
USDT_WALLET_ADDRESS=
# So lan/khoang thoi gian polling (ms)
USDT_POLL_INTERVAL_MS=60000

# ===== Payment: VietQR / Casso =====
# Thong tin tai khoan ngan hang de sinh VietQR
BANK_ID=970436
BANK_ACCOUNT_NO=
BANK_ACCOUNT_NAME=
# Secret token Casso gui kem webhook (Header: Secure-Token). Bat buoc de verify.
CASSO_WEBHOOK_SECRET=

# ===== Payment: The cao (TheSieuRe) =====
THESIEURE_PARTNER_ID=
THESIEURE_PARTNER_KEY=
THESIEURE_API_URL=https://thesieure.com/chargingws/v2

# ===== Email (Nodemailer SMTP) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="MMO Store <no-reply@mmostore.com>"

# ===== Seed admin =====
ADMIN_EMAIL=admin@mmostore.com
ADMIN_PASSWORD=Admin@12345
