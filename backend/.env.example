# ===========================================
# SERVER
# ===========================================
PORT=3000
NODE_ENV=development

# ===========================================
# DATABASE
# ===========================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mmo_store?schema=public"

# ===========================================
# REDIS
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# CACHE
# ===========================================
CACHE_TTL=300

# ===========================================
# JWT
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_ACCESS_SECRET=your-access-token-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production

# ===========================================
# FRONTEND
# ===========================================
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5173/admin

# ===========================================
# TELEGRAM BOT
# ===========================================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ADMIN_CHAT_ID=8504482438
TELEGRAM_NOTIFICATIONS_ENABLED=true

# ===========================================
# EMAIL (SMTP)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@mmostore.com

# ===========================================
# USDT TRC20 (TronGrid)
# ===========================================
TRONGRID_API_KEY=your-trongrid-api-key
USDT_DEPOSIT_ADDRESS=your-usdt-deposit-address

# ===========================================
# CASSO (Bank Webhook)
# ===========================================
CASSO_API_KEY=your-casso-api-key
CASSO_WEBHOOK_SECRET=your-casso-webhook-secret

# ===========================================
# THESIEURE
# ===========================================
THESIEURE_API_KEY=your-thesieure-api-key
THESIEURE_PARTNER_ID=your-partner-id

# ===========================================
# VIETQR
# ===========================================
VIETQR_BANK_ID=970436
VIETQR_ACCOUNT_NUMBER=1234567890
VIETQR_ACCOUNT_NAME=MMO STORE

# ===========================================
# FILE STORAGE
# ===========================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# CORS
# ===========================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3001
